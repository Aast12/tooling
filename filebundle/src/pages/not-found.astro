---
import Layout from "@/components/Layout.astro";
import Icon from "@/components/Icon.astro";
import IconTile from "@/components/IconTile.astro";
import StatusBar from "@/components/StatusBar.astro";
import ShortcutHint from "@/components/ShortcutHint.astro";
Astro.response.status = 404;
---
<Layout title="not found · filebundle">
  <div class="grid place-items-center text-center py-16">
    <IconTile size={56} variant="err" class="mb-6">
      <Icon name="alert" size={22} />
    </IconTile>
    <h1 class="m-0 font-display text-[38px] font-normal uppercase leading-none tracking-[0.02em]">
      Bundle <span class="text-err">not found</span>
    </h1>
    <p class="mt-3 max-w-[460px] text-base leading-[1.55] text-fg-2">
      It either expired and was hard-deleted from R2, or the slug is wrong.
      Bundles live for at most 7 days.
    </p>

    <div class="mt-7 flex gap-2.5">
      <a href="/" class="btn btn--primary">
        <Icon name="plus" size={14} />New bundle
      </a>
      <button type="button" class="btn" id="open-other">
        <Icon name="search" size={14} />Open another…
      </button>
    </div>
  </div>

  <StatusBar slot="status">
    <span class="slot"><span class="dot text-err"></span><span class="text-fg-1">Not found</span></span>
    <span class="slot" slot="right"><ShortcutHint keys={["/"]} label="Home" class="" /></span>
  </StatusBar>
</Layout>

<script is:inline>
  document.getElementById('open-other')?.addEventListener('click', () => {
    const input = document.querySelector('[data-bundle-nav] input[name="slug"]');
    if (input) {
      input.focus();
      input.scrollIntoView({ block: "nearest", behavior: "smooth" });
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLElement && /input|textarea/i.test(e.target.tagName)) return;
    if (e.key === '/') {
      e.preventDefault();
      const input = document.querySelector('[data-bundle-nav] input[name="slug"]');
      if (input) input.focus();
    }
  });
</script>
