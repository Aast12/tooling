---
import Layout from "@/components/Layout.astro";
import Icon from "@/components/Icon.astro";
import StatusBar from "@/components/StatusBar.astro";
import PageHeader from "@/components/PageHeader.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Dropzone from "@/components/Dropzone.astro";
import SnippetEditor from "@/components/SnippetEditor.astro";
import ShortcutHint from "@/components/ShortcutHint.astro";
import { EXPIRATION_CHOICES, DEFAULT_EXPIRATION } from "@/lib/expiration";
import { formatBytes, MAX_FILE_BYTES, MAX_TOTAL_BYTES, MAX_ITEMS } from "@/lib/validation";
---
<Layout title="filebundle">
  <PageHeader eyebrow="filebundle / new">
    New <span class="text-accent">bundle</span>
    <Fragment slot="sub">
      Drop files or paste snippets. Get a short URL and a QR code.
      Everything is hard-deleted when it expires.
    </Fragment>
  </PageHeader>

  <form
    id="upload-form"
    method="POST"
    action="/api/bundles"
    enctype="multipart/form-data"
    data-max-file={MAX_FILE_BYTES}
    data-max-total={MAX_TOTAL_BYTES}
  >
    <section class="section">
      <SectionHeader title="Files" hint="Optional · drop zone">
        <span class="text-sm text-fg-2">
          Max {formatBytes(MAX_FILE_BYTES)} per file · {formatBytes(MAX_TOTAL_BYTES)} total
        </span>
      </SectionHeader>

      <Dropzone inputId="file-input" />
      <ul id="file-list" class="hidden m-0 mt-3 list-none border border-line-1 bg-bg-1 p-0" role="list"></ul>
      <p id="upload-error" class="alert mt-3" hidden role="alert"></p>
    </section>

    <section class="section">
      <SectionHeader title="Snippets">
        <span class="text-sm text-fg-2 mr-3" id="snippet-hint">Optional</span>
        <button type="button" id="add-snippet" class="btn btn--ghost btn--sm">
          <Icon name="plus" size={13} />Add snippet
        </button>
      </SectionHeader>
      <div id="snippet-list" class="grid gap-3"></div>
      <SnippetEditor />
    </section>

    <section class="section">
      <SectionHeader title="Expires in" />
      <div class="seg" role="radiogroup" aria-label="expiration">
        {EXPIRATION_CHOICES.map((c) => (
          <button
            type="button"
            class="seg__opt"
            role="radio"
            data-exp={c}
            aria-pressed={c === DEFAULT_EXPIRATION ? "true" : "false"}
          >{c}</button>
        ))}
      </div>
      <input type="hidden" name="expiration" id="expiration-input" value={DEFAULT_EXPIRATION} />
      <p class="mt-2.5 text-sm text-fg-2">
        Bundles are hard-deleted from R2 the moment they expire.
      </p>
    </section>

    <div class="flex items-center gap-2.5 border-t border-line-1 pt-6">
      <button type="submit" class="btn btn--primary btn--lg">
        Create bundle <Icon name="arrow" size={14} />
      </button>
      <button type="reset" class="btn btn--lg">Reset</button>
      <span class="flex-1"></span>
      <ShortcutHint keys={["⌘", "↩"]} label="to submit" />
    </div>
  </form>

  <StatusBar slot="status">
    <span class="slot"><span class="dot text-ok"></span><span class="text-fg-1">Connected</span></span>
    <span class="sep">·</span>
    <span class="slot"><span id="status-items">0</span> of {MAX_ITEMS} items</span>
    <span class="sep">·</span>
    <span class="slot"><span id="status-bytes">0 B</span> of {formatBytes(MAX_TOTAL_BYTES)}</span>
    <span class="slot" slot="right"><ShortcutHint keys={["⌘", "↩"]} label="Submit" class="" /></span>
  </StatusBar>
</Layout>

<script is:inline>
  (function () {
    const form = document.getElementById("upload-form");
    const fileInput = document.getElementById("file-input");
    const dropzone = document.getElementById("dropzone");
    const fileList = document.getElementById("file-list");
    const errorEl = document.getElementById("upload-error");
    const statusItems = document.getElementById("status-items");
    const statusBytes = document.getElementById("status-bytes");
    const expInput = document.getElementById("expiration-input");
    const segOpts = document.querySelectorAll('.seg__opt[data-exp]');
    const maxFile = Number(form.dataset.maxFile);
    const maxTotal = Number(form.dataset.maxTotal);

    function fmt(n) {
      if (n < 1024) return n + " B";
      if (n < 1048576) return (n / 1024).toFixed(1) + " KB";
      if (n < 1073741824) return (n / 1048576).toFixed(1) + " MB";
      return (n / 1073741824).toFixed(2) + " GB";
    }

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.hidden = false;
      errorEl.scrollIntoView({ block: "nearest", behavior: "smooth" });
    }
    function clearError() {
      errorEl.textContent = "";
      errorEl.hidden = true;
    }

    function fileIconName(name) {
      if (/\.(png|jpe?g|gif|webp|svg)$/i.test(name)) return "image";
      if (/\.(sh|js|ts|py|rb|go|rs|java|tsx|jsx|c|cpp|json|yml|yaml|toml|md|css|html)$/i.test(name)) return "code";
      return "file";
    }

    const ICONS = {
      file:  '<path d="M4 1.5h5l3 3V14a.5.5 0 0 1-.5.5h-7.5A.5.5 0 0 1 3.5 14V2a.5.5 0 0 1 .5-.5z"/><path d="M9 1.5v3.5h3"/>',
      code:  '<path d="M5.5 4.5 2.5 8l3 3.5M10.5 4.5l3 3.5-3 3.5M9 3l-2 10"/>',
      image: '<rect x="2" y="3" width="12" height="10" rx="1"/><circle cx="6" cy="7" r="1"/><path d="m2.5 12 3-3 3 2.5L11 9l2.5 3"/>',
      x:     '<path d="M3.5 3.5l9 9M12.5 3.5l-9 9"/>',
    };
    function svg(name, size) {
      const s = size || 15;
      return '<svg width="' + s + '" height="' + s + '" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + ICONS[name] + '</svg>';
    }

    function renderFiles() {
      const files = fileInput.files ? Array.from(fileInput.files) : [];
      let total = 0;
      for (const f of files) total += f.size;

      if (files.length === 0) {
        dropzone.classList.remove("hidden");
        fileList.classList.add("hidden");
        fileList.innerHTML = "";
      } else {
        dropzone.classList.add("hidden");
        fileList.classList.remove("hidden");
        fileList.innerHTML = files.map((f, i) =>
          '<li class="row">' +
            '<span class="row__icon">' + svg(fileIconName(f.name)) + '</span>' +
            '<div><div class="row__name">' + escapeHtml(f.name) + '</div>' +
              '<div class="row__meta">' + fmt(f.size) + '</div></div>' +
            '<span></span>' +
            '<button type="button" class="btn btn--ghost btn--sm btn--icon" data-remove-file="' + i + '" aria-label="remove">' + svg("x", 14) + '</button>' +
          '</li>'
        ).join("");
      }

      const snippetCount = document.querySelectorAll('#snippet-list > div').length;
      statusItems.textContent = String(files.length + snippetCount);
      statusBytes.textContent = fmt(total);

      for (const btn of fileList.querySelectorAll('[data-remove-file]')) {
        btn.addEventListener('click', () => {
          const idx = Number(btn.getAttribute('data-remove-file'));
          const dt = new DataTransfer();
          const arr = Array.from(fileInput.files || []);
          arr.forEach((f, i) => { if (i !== idx) dt.items.add(f); });
          fileInput.files = dt.files;
          renderFiles();
        });
      }
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"})[c]);
    }

    function validateFiles() {
      const files = fileInput.files ? Array.from(fileInput.files) : [];
      let total = 0;
      for (const f of files) {
        if (f.size > maxFile) {
          return 'File "' + f.name + '" (' + fmt(f.size) + ') exceeds the ' + fmt(maxFile) + ' per-file limit.';
        }
        total += f.size;
      }
      if (total > maxTotal) {
        return "Bundle total (" + fmt(total) + ") would exceed the " + fmt(maxTotal) + " bundle limit.";
      }
      return null;
    }

    fileInput.addEventListener("change", () => {
      const err = validateFiles();
      if (err) { showError(err); fileInput.value = ""; }
      else { clearError(); }
      renderFiles();
    });

    let dragDepth = 0;
    function onDragEnter(e) { e.preventDefault(); dragDepth++; dropzone.classList.add("dropzone--drag"); }
    function onDragLeave() { dragDepth--; if (dragDepth <= 0) { dragDepth = 0; dropzone.classList.remove("dropzone--drag"); } }
    function onDrop(e) {
      e.preventDefault();
      dragDepth = 0;
      dropzone.classList.remove("dropzone--drag");
      if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files.length) {
        const dt = new DataTransfer();
        for (const f of fileInput.files || []) dt.items.add(f);
        for (const f of e.dataTransfer.files) dt.items.add(f);
        fileInput.files = dt.files;
        const err = validateFiles();
        if (err) { showError(err); fileInput.value = ""; }
        else { clearError(); }
        renderFiles();
      }
    }
    ['dragenter','dragover'].forEach((t) => document.addEventListener(t, (e) => e.preventDefault()));
    dropzone.addEventListener('dragenter', onDragEnter);
    dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add("dropzone--drag"); });
    dropzone.addEventListener('dragleave', onDragLeave);
    dropzone.addEventListener('drop', onDrop);

    document.addEventListener('drop', (e) => {
      if (e.target && e.target.closest && e.target.closest('#dropzone')) return;
      e.preventDefault();
      if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files.length) {
        const dt = new DataTransfer();
        for (const f of fileInput.files || []) dt.items.add(f);
        for (const f of e.dataTransfer.files) dt.items.add(f);
        fileInput.files = dt.files;
        const err = validateFiles();
        if (err) { showError(err); fileInput.value = ""; }
        else { clearError(); }
        renderFiles();
      }
    });

    form.addEventListener("submit", (ev) => {
      const err = validateFiles();
      if (err) { ev.preventDefault(); showError(err); }
    });

    segOpts.forEach((b) => {
      b.addEventListener('click', () => {
        segOpts.forEach((x) => x.setAttribute('aria-pressed', 'false'));
        b.setAttribute('aria-pressed', 'true');
        expInput.value = b.getAttribute('data-exp');
      });
    });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    // Snippets — uses shared <SnippetEditor /> template via window.buildSnippetEditor
    const snippetList = document.getElementById('snippet-list');
    const snippetHint = document.getElementById('snippet-hint');
    const addBtn = document.getElementById('add-snippet');
    let counter = 0;

    function updateSnippetHint() {
      const n = snippetList.children.length;
      snippetHint.textContent = n === 0 ? 'Optional' : (n + ' added');
      const files = fileInput.files ? Array.from(fileInput.files) : [];
      statusItems.textContent = String(files.length + n);
    }

    addBtn.addEventListener('click', () => {
      counter += 1;
      const node = window.buildSnippetEditor(counter, updateSnippetHint);
      snippetList.appendChild(node);
      updateSnippetHint();
    });

    renderFiles();
    updateSnippetHint();
  })();
</script>
