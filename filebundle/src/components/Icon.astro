---
interface Props {
  name:
    | "file" | "code" | "image" | "download" | "upload" | "copy" | "qr"
    | "clock" | "plus" | "trash" | "share" | "eye" | "lock" | "search"
    | "arrow" | "check" | "x" | "alert";
  size?: number;
  class?: string;
}
const { name, size = 16, class: className } = Astro.props;
const sw = 1.6;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 16 16"
  fill="none"
  stroke="currentColor"
  stroke-width={sw}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === "file" && (
    <>
      <path d="M4 1.5h5l3 3V14a.5.5 0 0 1-.5.5h-7.5A.5.5 0 0 1 3.5 14V2a.5.5 0 0 1 .5-.5z"/>
      <path d="M9 1.5v3.5h3"/>
    </>
  )}
  {name === "code" && (
    <path d="M5.5 4.5 2.5 8l3 3.5M10.5 4.5l3 3.5-3 3.5M9 3l-2 10"/>
  )}
  {name === "image" && (
    <>
      <rect x="2" y="3" width="12" height="10" rx="1"/>
      <circle cx="6" cy="7" r="1"/>
      <path d="m2.5 12 3-3 3 2.5L11 9l2.5 3"/>
    </>
  )}
  {name === "download" && (
    <path d="M8 2v8M4.5 7 8 10.5 11.5 7M3 13h10"/>
  )}
  {name === "upload" && (
    <path d="M8 13V5M4.5 8.5 8 5l3.5 3.5M3 13h10"/>
  )}
  {name === "copy" && (
    <>
      <rect x="3" y="3" width="8" height="8" rx="1"/>
      <path d="M5.5 13.5h7a.5.5 0 0 0 .5-.5v-7"/>
    </>
  )}
  {name === "qr" && (
    <>
      <rect x="2" y="2" width="4.5" height="4.5"/>
      <rect x="9.5" y="2" width="4.5" height="4.5"/>
      <rect x="2" y="9.5" width="4.5" height="4.5"/>
      <path d="M9 9h2v2M13 9v2M9 13h2M13 13v.5"/>
    </>
  )}
  {name === "clock" && (
    <>
      <circle cx="8" cy="8" r="6"/>
      <path d="M8 4.5V8l2.5 1.5"/>
    </>
  )}
  {name === "plus" && (
    <path d="M8 3v10M3 8h10"/>
  )}
  {name === "trash" && (
    <path d="M2.5 4h11M6 4V2.5h4V4M4 4l.6 9.5h6.8L12 4M7 7v4M9 7v4"/>
  )}
  {name === "share" && (
    <path d="M11 4 8 1.5 5 4M8 1.5V10M3 8.5V13a.5.5 0 0 0 .5.5h9a.5.5 0 0 0 .5-.5V8.5"/>
  )}
  {name === "eye" && (
    <>
      <path d="M1.5 8S4 3.5 8 3.5 14.5 8 14.5 8 12 12.5 8 12.5 1.5 8 1.5 8z"/>
      <circle cx="8" cy="8" r="2"/>
    </>
  )}
  {name === "lock" && (
    <>
      <rect x="3" y="7" width="10" height="7" rx="1"/>
      <path d="M5 7V5a3 3 0 0 1 6 0v2"/>
    </>
  )}
  {name === "search" && (
    <>
      <circle cx="7" cy="7" r="4.5"/>
      <path d="m13.5 13.5-3-3"/>
    </>
  )}
  {name === "arrow" && (
    <path d="M3.5 8h9M9 4.5 12.5 8 9 11.5"/>
  )}
  {name === "check" && (
    <path d="m3 8.5 3 3 7-7.5"/>
  )}
  {name === "x" && (
    <path d="M3.5 3.5l9 9M12.5 3.5l-9 9"/>
  )}
  {name === "alert" && (
    <>
      <path d="M8 1.5 14.5 13.5h-13z"/>
      <path d="M8 6v3M8 11v.5"/>
    </>
  )}
</svg>
