---
import Icon from "./Icon.astro";

interface Props {
  bundleId: string;
  bundleUrl: string;
  hostName: string;
  ageLabel: string;
  expiresAtMs: number;
  qrSvgHtml: string;
  /** show "Bundle ready" headline (just-created) instead of "Active bundle". */
  created?: boolean;
}
const { bundleId, bundleUrl, hostName, ageLabel, expiresAtMs, qrSvgHtml, created = false } = Astro.props;
---
<section class="dual mb-7">
  <div class="dual-h">
    <span class="inline-flex items-center gap-2">
      <span class="dot dot--pulse text-ok"></span>
      <span>Bundle</span>
      <span class="seq">/</span>
      <span class="font-mono normal-case tracking-normal text-fg-1">{bundleId}</span>
    </span>
    <span class="flex-1"></span>
    <span>created — {ageLabel}</span>
  </div>
  <div class="share-grid">
    <div>
      <h1>
        {created
          ? <>Bundle <span class="text-accent">ready</span></>
          : <>Active <span class="text-accent">bundle</span></>}
      </h1>
      <p class="mt-2 mb-5 max-w-[460px] text-sm text-fg-2">
        Anyone with the URL can read it. It expires in
        {" "}<span class="font-mono tabular-nums text-fg-1" data-countdown={expiresAtMs}>…</span>{" "}
        and is then hard-deleted from R2.
      </p>

      <div class="share-url">
        <span class="host">{hostName}/</span>
        <span class="slug">{bundleId}</span>
        <button type="button" class="btn btn--primary btn--sm h-8 rounded-none" data-copy={bundleUrl}>
          <span data-copy-default class="inline-flex items-center gap-2"><Icon name="copy" size={13} />Copy</span>
          <span data-copy-done class="hidden items-center gap-2"><Icon name="check" size={13} />Copied</span>
        </button>
      </div>

      <div class="mt-3.5 flex gap-2.5">
        <button type="button" class="btn btn--sm" data-share-url={bundleUrl}>
          <Icon name="share" size={13} />Share
        </button>
        <button type="button" class="btn btn--sm" data-toggle-qr aria-expanded="true">
          <Icon name="qr" size={13} />Hide QR
        </button>
      </div>
    </div>
    <div id="qr-frame" class="bracketed share-qr">
      <span class="bk-tr"></span><span class="bk-bl"></span>
      <Fragment set:html={qrSvgHtml} />
      <div class="share-qr__caption">Scan</div>
    </div>
  </div>
</section>
