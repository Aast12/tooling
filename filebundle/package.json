{
  "name": "filebundle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate:local": "wrangler d1 migrations apply filebundle --local",
    "migrate:prod": "wrangler d1 migrations apply filebundle --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@tailwindcss/vite": "~4.1.11",
    "astro": "^6.1.4",
    "shiki": "^1.22.0",
    "tailwindcss": "~4.1.11"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "better-sqlite3": "^12.9.0",
    "miniflare": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "wrangler": "^4.84.1"
  }
}
